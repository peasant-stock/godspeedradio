<header>
  <div class="logo">
    <a href="/">GODSPEED RADIO</a>
  </div>

  <button class="hamburger" id="hamburger-btn" aria-label="Open menu">
    <span></span>
    <span></span>
    <span></span>
  </button>
</header>

<nav id="main-nav">
    <button class="close-btn" id="close-btn" aria-label="Close menu">x</button>
    <a href="#residents">RESIDENTS</a>
    <a href="#schedule">SCHEDULE</a>
</nav>

<div class="nav-overlay" id="nav-overlay"></div>

<script>
    const hamburger = document.getElementById("hamburger-btn")!;
    const nav = document.getElementById("main-nav")!;
    const overlay = document.getElementById("nav-overlay")!;
    const closeBtn = document.getElementById("close-btn")!;

    function openMenu() {
        nav.classList.add("open");
        overlay.classList.add("open");
        hamburger.setAttribute("aria-label", "Close menu");
    }

    function closeMenu() {
        nav.classList.remove("open");
        overlay.classList.remove("open");
        hamburger.setAttribute("aria-label", "Open menu");
    }

    hamburger?.addEventListener("click", () => {
        nav.classList.contains("open") ? closeMenu() : openMenu();
    });

    overlay.addEventListener("click", closeMenu);

    closeBtn.addEventListener("click", closeMenu);

    nav.querySelectorAll("a").forEach(link => {
        link.addEventListener("click", closeMenu);
    });
</script>

<style>
    header {
    position: sticky;
    top: 0;
    z-index: 1000;
    height: 72px;

    background: var(--black);
    color: var(--green);
    font-family: var(--body-font);

    display: flex;
    flex-wrap: nowrap;
    justify-content: space-between;
    align-items: center;

    padding: 0 2rem;
    }

    .logo {
        font-size: 2rem;
        font-weight: bold;
    }

    .logo a {
        color: var(--green);
        text-decoration: none;
    }

    nav {
    display: flex;
    gap: 1rem;
    }

    nav a {
    font-size: 1rem;
    font-weight: bold;
    color: var(--green);
    text-decoration: none;
    }

    nav a:hover {
        color: var(--gray);
    }

    .hamburger {
        display: none;
        flex-direction: column;
        justify-content: space-between;
        width: 1.5rem;
        height: 1.1rem;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        z-index: 1001;
    }

    .hamburger span {
        display: block;
        width: 100%;
        height: 2px;
        background: var(--green);
    }

    .nav-overlay {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 1001;
    }

    @media (min-width: 769px) {
    nav {
        position: fixed;
        top: 0;
        right: 2rem;
        height: 72px;
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 1rem;
        transform: none;
        background: none;
        z-index: 1001;
    }
    }

    @media (max-width: 768px) {
        nav.open .close-btn {
            display: block;
        }
        .hamburger {
            display: flex;
        }
        nav {
            position: fixed;
            top: 0;
            right: 0;
            width: 250px;
            height: 100vh;
            background: var(--black);
            flex-direction: column;
            justify-content: flex-start;
            align-items: flex-end;
            padding-top: 5rem;
            padding-right: 1.5rem;
            gap: 2rem;
            z-index: 1002;
            transform: translateX(100%);
            transition: transform 0.3s ease;
        }
        nav.open {
            transform: translateX(0);
        }
        nav a {
            font-size: 1.5rem;
        }
        .nav-overlay.open {
            display: block;
        }
    }

    /*@media (max-width: 480px) {
        .logo {
            font-size: 1.25rem;
        }
    }*/

    .close-btn {
        display: none;
        position: absolute;
        top: 1rem;
        right: 1rem;
        background: none;
        border: none;
        color: var(--green);
        font-size: 1.5rem;
        cursor: pointer;
        padding: 0.5rem;
    }
</style>