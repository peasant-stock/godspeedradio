---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Player from "../components/Player.astro";
import Papa from "papaparse";

const CSV_URL = "https://docs.google.com/spreadsheets/d/e/2PACX-1vRblmTAoiB1uszXYgUFdifv-vU5nVfzjDj58gfbjLt6NbRTgvgFrrPt4tJBWAGYwViNgS9QjPB_fjgF/pub?gid=0&single=true&output=csv";

const response = await fetch(CSV_URL);
const csvText = await response.text();
const { data: residents } = Papa.parse(csvText, {
	header: true,
	skipEmptyLines: true,
});

function slugify(name) {
	return name
		.toLowerCase()
		.trim()
		.replace(/[^a-z0-9\s-]/g, "")
		.replace(/\s+/g, "-");
}
---

<MainLayout title="Godspeed Radio">
  <Header />

  <Player />

  <main>
    <section class="hero">
      <p>
        This site is under construction 🔨ฅ^•ﻌ•^ฅ
      </p>
    </section>

	<section id="residents" class="block">
		<div class="block-content">
			<h2>RESIDENTS</h2>
			<div class="residents-grid">
				{residents.map((resident) => (
					<a 
						href={`/residents/${slugify(resident["Resident Name"])}`} 
						class="resident-tile"
						target="_blank"
						rel="noopener"
					>
						<img src={resident["Resident Photo Path"]} alt={resident["Resident Name"]} />
						<p>{resident["Resident Name"]}</p>
					</a>
				))}
			</div>
		</div>
	</section>

	<section id="schedule" class="block">
		<div class="block-content">
			<h2>SCHEDULE</h2>
		</div>
	</section>


  </main>

  <Footer />
</MainLayout>